# ─── Database ────────────────────────────────
DATABASE_URL="postgresql://isp_erp:isp_erp_secret@localhost:5432/isp_erp?schema=public"

# ─── Redis ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ─────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRES_IN=7d

# ─── API ─────────────────────────────────────
API_PORT=3001
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000

# ─── Frontend ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ─── File Storage ────────────────────────────
UPLOAD_DIR=./uploads

# ─── MikroTik (per router, configured in DB) ─
# MIKROTIK_DEFAULT_PORT=8728

# ─── Notifications ───────────────────────────
# SMS_PROVIDER=
# SMS_API_KEY=
# WHATSAPP_API_KEY=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
