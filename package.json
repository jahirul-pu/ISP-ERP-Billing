{
  "name": "isp-erp",
  "version": "1.0.0",
  "private": true,
  "description": "ISP ERP Billing & Operations Platform",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @isp-erp/database generate",
    "db:migrate": "pnpm --filter @isp-erp/database migrate",
    "db:seed": "pnpm --filter @isp-erp/database seed",
    "db:studio": "pnpm --filter @isp-erp/database studio"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@11.2.2"
}
